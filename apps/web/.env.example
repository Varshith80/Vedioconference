# =====================================================================
# Public (browser) environment variables
# ---------------------------------------------------------------------
# Only NEXT_PUBLIC_* variables are exposed to the browser. Never put
# secrets here. All real secrets belong in server-only env.
# =====================================================================

# --- Supabase ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Paris

# --- Calendly (public profile link) -----------------------------------
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-org

# --- n8n (public webhook entry points) --------------------------------
NEXT_PUBLIC_N8N_BOOKING_WEBHOOK=

# =====================================================================
# Server-only secrets (NEVER prefix with NEXT_PUBLIC_)
# =====================================================================

# --- Supabase (service role) -------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PAYG=
STRIPE_PRICE_SUBSCRIPTION=

# --- Zoom (server-to-server OAuth) ------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_DEFAULT_HOST_USER_ID=

# --- Calendly (personal access token) ---------------------------------
CALENDLY_PERSONAL_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=

# --- Resend ------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com

# --- n8n ---------------------------------------------------------------
N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# --- Misc --------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
